const { Client, GatewayIntentBits, REST, Routes, SlashCommandBuilder } = require("discord.js");
const Database = require("better-sqlite3");

const TOKEN = process.env.TOKEN;
const CLIENT_ID = process.env.CLIENT_ID;

const client = new Client({
  intents: [
    GatewayIntentBits.Guilds,
    GatewayIntentBits.GuildMessages,
    GatewayIntentBits.MessageContent,
  ],
});

const db = new Database("data.db");

// DB
db.prepare("CREATE TABLE IF NOT EXISTS users (id TEXT PRIMARY KEY, coins INTEGER, lastMsg INTEGER)").run();
db.prepare("CREATE TABLE IF NOT EXISTS shop (name TEXT PRIMARY KEY, price INTEGER)").run();

function getUser(id) {
  let user = db.prepare("SELECT * FROM users WHERE id=?").get(id);
  if (!user) {
    db.prepare("INSERT INTO users (id, coins, lastMsg) VALUES (?, 0, 0)").run(id);
    user = { id, coins: 0, lastMsg: 0 };
  }
  return user;
}

// COINS SYSTEM
client.on("messageCreate", (msg) => {
  if (msg.author.bot) return;

  const user = getUser(msg.author.id);
  const now = Date.now();

  if (now - user.lastMsg >= 15000) {
    db.prepare("UPDATE users SET coins = coins + 1, lastMsg=? WHERE id=?")
      .run(now, msg.author.id);
  }
});

// COMMANDS
const commands = [
  new SlashCommandBuilder().setName("balance").setDescription("Check coins"),
  new SlashCommandBuilder().setName("shop").setDescription("View shop"),
  new SlashCommandBuilder()
    .setName("buy")
    .addStringOption(o => o.setName("item").setRequired(true))
    .setDescription("Buy item"),
].map(c => c.toJSON());

const rest = new REST({ version: "10" }).setToken(TOKEN);

client.once("ready", async () => {
  console.log("Bot ready");

  await rest.put(Routes.applicationCommands(CLIENT_ID), {
    body: commands,
  });
});

// COMMAND HANDLER
client.on("interactionCreate", async (i) => {
  if (!i.isChatInputCommand()) return;

  const user = getUser(i.user.id);

  if (i.commandName === "balance") {
    return i.reply(`💰 Coins: ${user.coins}`);
  }

  if (i.commandName === "shop") {
    const items = db.prepare("SELECT * FROM shop").all();
    if (!items.length) return i.reply("Shop empty");

    return i.reply(items.map(x => `${x.name} - ${x.price}`).join("\n"));
  }

  if (i.commandName === "buy") {
    const name = i.options.getString("item");
    const item = db.prepare("SELECT * FROM shop WHERE name=?").get(name);

    if (!item) return i.reply("Not found");

    if (user.coins < item.price)
      return i.reply("Not enough coins");

    db.prepare("UPDATE users SET coins = coins - ? WHERE id=?")
      .run(item.price, i.user.id);

    return i.reply(`Bought ${name}`);
  }
});

client.login(TOKEN);
